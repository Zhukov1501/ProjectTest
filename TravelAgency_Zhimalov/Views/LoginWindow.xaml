<Window x:Class="TravelAgencyApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Турагентство - Авторизация" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Border Style="{StaticResource CardStyle}" 
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="350" Margin="20">
            <StackPanel>
                <TextBlock Text="ТУРАГЕНТСТВО" FontSize="28" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Система управления" FontSize="14" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Вход в систему" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" 
                         Margin="0,0,0,15" KeyDown="txtUsername_KeyDown"/>

                <TextBlock Text="Пароль" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             Padding="12,10" FontSize="14"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,5" KeyDown="txtPassword_KeyDown"/>

                <CheckBox x:Name="chkShowPassword" Content="Показать пароль" 
                          Margin="0,0,0,20" Checked="chkShowPassword_Changed" 
                          Unchecked="chkShowPassword_Changed"
                          Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="txtPasswordVisible" Visibility="Collapsed"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,5"/>

                <TextBlock x:Name="txtError" Foreground="{StaticResource ErrorBrush}" 
                           FontSize="12" TextAlignment="Center" Margin="0,0,0,15"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <Button x:Name="btnLogin" Content="Войти" Style="{StaticResource PrimaryButton}"
                        Width="200" Click="btnLogin_Click" Margin="0,10,0,0"/>

                <TextBlock Text="Демо-аккаунты:" FontSize="11" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,25,0,5"/>
                <TextBlock Text="admin / admin123 (Администратор)" FontSize="11" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="manager / manager123 (Менеджер)" FontSize="11" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="user / user123 (Пользователь)" FontSize="11" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
