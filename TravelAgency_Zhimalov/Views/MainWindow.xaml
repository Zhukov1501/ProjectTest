<Window x:Class="TravelAgencyApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Турагентство - Главное меню" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="ТУРАГЕНТСТВО" FontSize="20" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtUserInfo" FontSize="12" Foreground="#BBDEFB" 
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
                <Button Content="Выйти" HorizontalAlignment="Right" Click="btnLogout_Click"
                        Style="{StaticResource SecondaryButton}" Foreground="White"
                        BorderBrush="White" Padding="15,5"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="20" BorderThickness="0" Background="Transparent">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Клиенты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Управление клиентами" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="btnAddClient" Content="+ Добавить клиента" 
                                Style="{StaticResource PrimaryButton}" Margin="30,0,0,0"
                                Click="btnAddClient_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Поиск и фильтрация" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtClientSearch" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                         TextChanged="txtClientSearch_TextChanged"/>
                                <ComboBox x:Name="cmbClientSort" Grid.Column="1" Width="150" Margin="10,0"
                                          SelectionChanged="cmbClientSort_SelectionChanged">
                                    <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                                    <ComboBoxItem Content="По фамилии"/>
                                    <ComboBoxItem Content="По имени"/>
                                    <ComboBoxItem Content="По дате рождения"/>
                                    <ComboBoxItem Content="По дате регистрации"/>
                                    <ComboBoxItem Content="По телефону"/>
                                </ComboBox>
                                <CheckBox x:Name="chkClientAsc" Grid.Column="2" Content="По возрастанию" 
                                          IsChecked="True" VerticalAlignment="Center"
                                          Checked="chkClientSort_Changed" Unchecked="chkClientSort_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="dgClients" AutoGenerateColumns="False" 
                                  IsReadOnly="True" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  MouseDoubleClick="dgClients_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="120"/>
                                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                                <DataGridTextColumn Header="Паспорт" Binding="{Binding PassportNumber}" Width="110"/>
                                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Туры">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Туры турагентства" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="btnAddService" Content="+ Добавить тур" 
                                Style="{StaticResource PrimaryButton}" Margin="30,0,0,0"
                                Click="btnAddTour_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Поиск, фильтрация и сортировка" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="txtServiceSearch" Grid.Row="0" Grid.Column="0" 
                                         Style="{StaticResource ModernTextBox}" Margin="0,0,10,10"
                                         TextChanged="txtServiceSearch_TextChanged"/>
                                
                                <ComboBox x:Name="cmbTourType" Grid.Row="0" Grid.Column="1" 
                                          Margin="0,0,10,10" SelectionChanged="cmbTourType_SelectionChanged">
                                    <ComboBoxItem Content="Все типы" IsSelected="True"/>
                                </ComboBox>
                                
                                <ComboBox x:Name="cmbCountry" Grid.Row="0" Grid.Column="2" 
                                          Margin="0,0,10,10" SelectionChanged="cmbCountry_SelectionChanged">
                                    <ComboBoxItem Content="Все страны" IsSelected="True"/>
                                </ComboBox>

                                <ComboBox x:Name="cmbServiceSort" Grid.Row="0" Grid.Column="3" Margin="0,0,0,10"
                                          SelectionChanged="cmbServiceSort_SelectionChanged">
                                    <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                                    <ComboBoxItem Content="По названию"/>
                                    <ComboBoxItem Content="По цене"/>
                                    <ComboBoxItem Content="По стране"/>
                                    <ComboBoxItem Content="По типу"/>
                                    <ComboBoxItem Content="По длительности"/>
                                </ComboBox>

                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Цена:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtMinPrice" Width="80" Style="{StaticResource ModernTextBox}" 
                                             Margin="0,0,5,0" TextChanged="txtPrice_TextChanged"/>
                                    <TextBlock Text="-" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBox x:Name="txtMaxPrice" Width="80" Style="{StaticResource ModernTextBox}" 
                                             Margin="5,0,10,0" TextChanged="txtPrice_TextChanged"/>
                                </StackPanel>
                                
                                <CheckBox x:Name="chkServiceAsc" Grid.Row="1" Grid.Column="3" 
                                          Content="По возрастанию" IsChecked="True" VerticalAlignment="Center"
                                          Checked="chkServiceSort_Changed" Unchecked="chkServiceSort_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid x:Name="dgServices" AutoGenerateColumns="False" 
                                  IsReadOnly="True" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  MouseDoubleClick="dgServices_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                                <DataGridTextColumn Header="Название тура" Binding="{Binding Name}" Width="180"/>
                                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="130"/>
                                <DataGridTextColumn Header="Город" Binding="{Binding City}" Width="100"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding TourType}" Width="90"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:N0} ₽'}" Width="100"/>
                                <DataGridTextColumn Header="Дней" Binding="{Binding DurationDays}" Width="60"/>
                                <DataGridTextColumn Header="Отель" Binding="{Binding HotelName}" Width="130"/>
                                <DataGridTextColumn Header="★" Binding="{Binding HotelStars}" Width="50"/>
                                <DataGridTextColumn Header="Питание" Binding="{Binding MealType}" Width="100"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
