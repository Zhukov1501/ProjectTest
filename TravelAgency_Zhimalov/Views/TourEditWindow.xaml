<Window x:Class="TravelAgencyApp.Views.TourEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тур" Height="650" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" Text="Добавить тур" 
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название тура *" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>

                <TextBlock Text="Описание" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDescription" Style="{StaticResource ModernTextBox}" 
                         AcceptsReturn="True" Height="80" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Страна *" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCountry" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Город" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCity" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Тип тура *" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbTourType" IsEditable="True" Margin="0,0,0,10" FontSize="14">
                            <ComboBoxItem Content="Пляжный"/>
                            <ComboBoxItem Content="Экскурсионный"/>
                            <ComboBoxItem Content="Горнолыжный"/>
                            <ComboBoxItem Content="Круиз"/>
                            <ComboBoxItem Content="Оздоровительный"/>
                            <ComboBoxItem Content="Приключенческий"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Цена (₽) *" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPrice" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Длительность (дней)" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDurationDays" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Макс. участников" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMaxParticipants" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Название отеля" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtHotelName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Звёзды отеля" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbHotelStars" Margin="0,0,0,10" FontSize="14">
                            <ComboBoxItem Content="3*" IsSelected="True"/>
                            <ComboBoxItem Content="4*"/>
                            <ComboBoxItem Content="5*"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Тип питания" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbMealType" Margin="0,0,0,10" FontSize="14">
                            <ComboBoxItem Content="Завтрак" IsSelected="True"/>
                            <ComboBoxItem Content="Полупансион"/>
                            <ComboBoxItem Content="Всё включено"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Доступных мест" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtAvailableSlots" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <CheckBox x:Name="chkIsAvailable" Content="Доступен для бронирования" 
                                  IsChecked="True" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnDelete" Content="Удалить" Visibility="Collapsed"
                    Style="{StaticResource SecondaryButton}" Foreground="{StaticResource ErrorBrush}"
                    BorderBrush="{StaticResource ErrorBrush}" Margin="0,0,10,0"
                    Click="btnDelete_Click"/>
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}" 
                    Margin="0,0,10,0" Click="btnCancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" 
                    Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
