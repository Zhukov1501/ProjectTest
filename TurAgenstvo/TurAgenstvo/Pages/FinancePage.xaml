<Page x:Class="TurAgenstvo.Pages.FinancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Финансы"
      Background="#ECF0F1"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="ФИНАНСОВЫЙ УЧЕТ" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   Grid.Row="0"
                   Margin="0,0,0,20"/>

        <!-- Панель информации -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#27AE60" 
                    Grid.Column="0"
                    CornerRadius="5"
                    Margin="0,0,10,0"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="ОБЩАЯ ВЫРУЧКА" 
                               Foreground="White" 
                               FontSize="12"/>
                    <TextBlock x:Name="TotalRevenueText" 
                               Text="0 ₽" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#3498DB" 
                    Grid.Column="1"
                    CornerRadius="5"
                    Margin="10,0,10,0"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="ОПЛАЧЕННЫХ БРОНЕЙ" 
                               Foreground="White" 
                               FontSize="12"/>
                    <TextBlock x:Name="PaidBookingsText" 
                               Text="0" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F39C12" 
                    Grid.Column="2"
                    CornerRadius="5"
                    Margin="10,0,0,0"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="ОЖИДАЮТ ОПЛАТЫ" 
                               Foreground="White" 
                               FontSize="12"/>
                    <TextBlock x:Name="PendingBookingsText" 
                               Text="0" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Панель кнопок -->
        <StackPanel Orientation="Horizontal" 
                    Grid.Row="2" 
                    Margin="0,0,0,20">

            <Button Content="Выйти" 
                    Width="100" 
                    Height="35"
                    Background="#E74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="LogoutButton_Click"/>

            <Button Content="Провести оплату" 
                    Width="150" 
                    Height="35"
                    Margin="10,0,0,0"
                    Background="#27AE60"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ProcessPaymentButton_Click"/>

            <ComboBox x:Name="PeriodFilter" 
                      Width="120"
                      Height="35"
                      Margin="10,0,0,0"
                      SelectionChanged="PeriodFilter_SelectionChanged">
                <ComboBoxItem Content="За все время" IsSelected="True"/>
                <ComboBoxItem Content="За сегодня"/>
                <ComboBoxItem Content="За неделю"/>
                <ComboBoxItem Content="За месяц"/>
                <ComboBoxItem Content="За год"/>
            </ComboBox>
        </StackPanel>

        <!-- Таблица финансовых операций -->
        <DataGrid x:Name="FinanceGrid" 
                  Grid.Row="3"
                  Style="{StaticResource DataGridStyle}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="FinanceGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№ операции" 
                                     Width="120"
                                     Binding="{Binding OperationNumber}"/>

                <DataGridTextColumn Header="Дата" 
                                     Width="120"
                                     Binding="{Binding OperationDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>

                <DataGridTextColumn Header="Тип" 
                                     Width="100"
                                     Binding="{Binding OperationType}"/>

                <DataGridTextColumn Header="Сумма" 
                                     Width="120"
                                     Binding="{Binding Amount, StringFormat={}{0:N0} ₽}"/>

                <DataGridTextColumn Header="Номер брони" 
                                     Width="120"
                                     Binding="{Binding Booking.BookingNumber}"/>

                <DataGridTextColumn Header="Клиент" 
                                     Width="150"
                                     Binding="{Binding Booking.Client.LastName}"/>

                <DataGridTextColumn Header="Описание" 
                                     Width="200"
                                     Binding="{Binding Description}"/>

                <DataGridTextColumn Header="Бухгалтер" 
                                     Width="150"
                                     Binding="{Binding Employee.LastName}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>