<Page x:Class="TurAgenstvo.Pages.AdminMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Меню администратора"
      Background="#ECF0F1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="МЕНЮ АДМИНИСТРАТОРА" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,20"
                   Grid.Row="0"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="300">

            <Button Content="СОТРУДНИКИ" 
                    Style="{StaticResource MainButtonStyle}"
                    Background="#3498DB"
                    Margin="0,0,0,15"
                    Height="50"
                    Click="EmployeesButton_Click"/>

            <Button Content="ТУРЫ" 
                    Style="{StaticResource MainButtonStyle}"
                    Background="#27AE60"
                    Margin="0,0,0,15"
                    Height="50"
                    Click="ToursButton_Click"/>

            <Button Content="ФИНАНСЫ" 
                    Style="{StaticResource MainButtonStyle}"
                    Background="#E67E22"
                    Margin="0,0,0,15"
                    Height="50"
                    Click="FinanceButton_Click"/>
        </StackPanel>
    </Grid>
</Page>