<Window x:Class="TurAgenstvo.Pages.AddBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новое бронирование" 
        Height="600" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="НОВОЕ БРОНИРОВАНИЕ" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Grid.Row="0"
                   Margin="0,0,0,20"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="ДАННЫЕ КЛИЕНТА" Margin="0,0,0,15" Padding="10">
                    <StackPanel>
                        <!-- ФИО -->
                        <TextBlock Text="ФИО клиента:*" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ClientNameBox" Height="30" Margin="0,0,0,10"/>

                        <!-- Телефон -->
                        <TextBlock Text="Контактный телефон:*" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ClientPhoneBox" Height="30" Margin="0,0,0,10"/>

                        <!-- Email -->
                        <TextBlock Text="Email:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ClientEmailBox" Height="30" Margin="0,0,0,10"/>

                        <!-- Паспортные данные -->
                        <TextBlock Text="Серия паспорта:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="PassportSeriesBox" Height="30" Margin="0,0,0,10"/>

                        <TextBlock Text="Номер паспорта:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="PassportNumberBox" Height="30" Margin="0,0,0,10"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="ВЫБОР ТУРА" Margin="0,0,0,15" Padding="10">
                    <StackPanel>
                        <!-- Выбор тура -->
                        <TextBlock Text="Тур:*" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="TourComboBox" 
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="TourID"
                                  Height="35" 
                                  Margin="0,0,0,10"
                                  SelectionChanged="TourComboBox_SelectionChanged"/>

                        <!-- Информация о туре -->
                        <Border Background="#F0F0F0" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="TourInfoText" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Даты -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Дата заезда:*" FontWeight="Bold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="StartDatePicker" Height="30"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Дата выезда:*" FontWeight="Bold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="EndDatePicker" Height="30"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="КОЛИЧЕСТВО ТУРИСТОВ" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Взрослых:*" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="AdultsCountBox" 
                                     Height="30" 
                                     Text="1"
                                     TextChanged="AdultsCountBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Детей:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="ChildrenCountBox" 
                                     Height="30" 
                                     Text="0"
                                     TextChanged="ChildrenCountBox_TextChanged"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ИТОГОВАЯ СУММА -->
                <Border Background="#27AE60" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="ИТОГО К ОПЛАТЕ:" 
                                   Foreground="White" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalPriceText" 
                                   Text="0 ₽" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" 
                    Grid.Row="2" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Забронировать" 
                    Width="120" 
                    Height="35"
                    Background="#27AE60"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="BookButton_Click"/>

            <Button Content="Сохранить и оплатить" 
                    Width="150" 
                    Height="35"
                    Background="#F39C12"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="BookAndPayButton_Click"/>

            <Button Content="Отмена" 
                    Width="100" 
                    Height="35"
                    Background="#E74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>