<Page x:Class="TurAgenstvo.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация"
      Background="#ECF0F1">

    <Grid>
        <!-- Центрируем форму -->
        <Border Background="White" 
                Width="350" 
                Height="300" 
                CornerRadius="10" 
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel VerticalAlignment="Center">
                <!-- Логотип/Заголовок -->
                <TextBlock Text="ВХОД В СИСТЕМУ" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Поле Логин -->
                <TextBlock Text="Логин:" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="LoginBox" 
                         Height="35" 
                         Padding="10"
                         Margin="0,0,0,15"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"/>

                <!-- Поле Пароль -->
                <TextBlock Text="Пароль:" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PassBox" 
                             Height="35" 
                             Padding="10"
                             Margin="0,0,0,20"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"/>

                <!-- Кнопка входа -->
                <Button x:Name="LoginButton"
                        Content="ВОЙТИ" 
                        Height="40"
                        Background="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>

                <!-- Статус -->
                <TextBlock x:Name="StatusText" 
                           Foreground="Red" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>