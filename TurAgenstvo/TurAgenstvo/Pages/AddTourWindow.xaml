<Window x:Class="TurAgenstvo.Pages.AddTourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый тур"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="ДОБАВИТЬ ТУР"
                   FontSize="18" FontWeight="Bold" Foreground="#2C3E50"
                   Grid.Row="0" Grid.ColumnSpan="2"
                   Margin="0,0,0,15"/>

        <!-- Название -->
        <TextBlock Text="Название тура *" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="TourNameBox" Grid.Row="1" Grid.Column="1" Height="30" Padding="5,3" Margin="0,0,0,8"/>

        <!-- Страна -->
        <TextBlock Text="Страна *" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox x:Name="CountryComboBox" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,0,8"
                  DisplayMemberPath="CountryName" SelectedValuePath="CountryId"
                  SelectionChanged="CountryComboBox_SelectionChanged"/>

        <!-- Город -->
        <TextBlock Text="Город *" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox x:Name="CityComboBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,0,8"
                  DisplayMemberPath="CityName" SelectedValuePath="CityId"
                  SelectionChanged="CityComboBox_SelectionChanged"/>

        <!-- Отель -->
        <TextBlock Text="Отель" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox x:Name="HotelComboBox" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,0,0,8"
                  DisplayMemberPath="HotelName" SelectedValuePath="HotelId"/>

        <!-- Дата вылета -->
        <TextBlock Text="Дата вылета *" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <DatePicker x:Name="DepartureDatePicker" Grid.Row="5" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

        <!-- Дата возврата -->
        <TextBlock Text="Дата возврата *" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <DatePicker x:Name="ReturnDatePicker" Grid.Row="6" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

        <!-- Цена -->
        <TextBlock Text="Цена (руб) *" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="PriceBox" Grid.Row="7" Grid.Column="1" Height="30" Padding="5,3" Margin="0,0,0,8" Text="0"/>

        <!-- Макс. туристов -->
        <TextBlock Text="Мест *" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="MaxTouristsBox" Grid.Row="8" Grid.Column="1" Height="30" Padding="5,3" Margin="0,0,0,8" Text="10"/>

        <!-- Описание -->
        <TextBlock Text="Описание" Grid.Row="9" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,8"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="9" Grid.Column="1" Height="60" Padding="5,3" Margin="0,0,0,8"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <!-- Активен -->
        <CheckBox x:Name="IsActiveCheck" Grid.Row="10" Grid.Column="1"
                  Content="Тур активен" IsChecked="True" Margin="0,0,0,15" VerticalAlignment="Center"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Grid.Row="11" Grid.ColumnSpan="2">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" Width="100" Height="32"
                    Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
