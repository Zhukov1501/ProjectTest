<Window x:Class="TurAgenstvo.Pages.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление сотрудника" 
        Height="450" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="НОВЫЙ СОТРУДНИК" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Grid.Row="0"
                   Margin="0,0,0,20"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Должность -->
                <TextBlock Text="Должность:*" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="PositionComboBox" 
                          DisplayMemberPath="PositionName"
                          SelectedValuePath="PositionID"
                          Height="35" 
                          Margin="0,0,0,15"/>

                <!-- Фамилия -->
                <TextBlock Text="Фамилия:*" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LastNameBox" Height="35" Margin="0,0,0,15"/>

                <!-- Имя -->
                <TextBlock Text="Имя:*" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="FirstNameBox" Height="35" Margin="0,0,0,15"/>

                <!-- Отчество -->
                <TextBlock Text="Отчество:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="MiddleNameBox" Height="35" Margin="0,0,0,15"/>

                <!-- Логин -->
                <TextBlock Text="Логин:*" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginBox" Height="35" Margin="0,0,0,15"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль:*" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="35" Margin="0,0,0,15"/>

                <!-- Email -->
                <TextBlock Text="Email:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailBox" Height="35" Margin="0,0,0,15"/>

                <!-- Телефон -->
                <TextBlock Text="Телефон:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneBox" Height="35" Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" 
                    Grid.Row="2" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Сохранить" 
                    Width="100" 
                    Height="35"
                    Background="#27AE60"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена" 
                    Width="100" 
                    Height="35"
                    Background="#E74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>