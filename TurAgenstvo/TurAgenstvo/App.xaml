<Application x:Class="TurAgenstvo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TurAgenstvo.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- КОНВЕРТЕРЫ -->
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter"/>
        <converters:PriceConverter x:Key="PriceConverter"/>

        <!-- УНИКАЛЬНЫЕ ЦВЕТА -->
        <SolidColorBrush x:Key="AdminButtonBackground" Color="#1ABC9C"/>
        <SolidColorBrush x:Key="ManagerButtonBackground" Color="#3498DB"/>
        <SolidColorBrush x:Key="AccountantButtonBackground" Color="#9B59B6"/>
        <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
        <SolidColorBrush x:Key="ButtonHoverBackground" Color="#34495E"/>

        <!-- СТИЛЬ КНОПКИ -->
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AdminButtonBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛЬ ДЛЯ ТАБЛИЦ -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="#F0F0F0"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

    </Application.Resources>
</Application>